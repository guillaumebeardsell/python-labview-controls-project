{
  "name": "Python + Claude Code",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && npm install -g @anthropic-ai/claude-code && mkdir -p ~/.local/bin && printf '#!/bin/bash\\nclaude --dangerously-skip-permissions\\n' > ~/.local/bin/cl && chmod +x ~/.local/bin/cl && bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "args": [
              "-l"
            ]
          }
        }
      }
    }
  },
  "mounts": [
    "source=${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],
  "runArgs": [
    "--network=host"
  ]
}